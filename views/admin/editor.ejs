<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title><%= post ? 'Edit' : 'New' %> Post — <%= site.site_title %></title>
<link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<% const navActive = post ? 'posts' : 'new'; %>
<%- include('_nav') %>

<div class="container">
  <form action="<%= post ? '/admin/posts/' + post.id + '/edit' : '/admin/posts/new' %>" method="POST" data-post-id="<%= post ? post.id : 'new' %>">

    <div class="page-header">
      <h1><%= post ? 'Edit Post' : 'New Post' %></h1>
      <div style="display:flex;gap:8px">
        <a href="/admin/posts" class="btn btn-ghost">Cancel</a>
        <% if (post && post.status === 'published') { %>
          <a href="/post/<%= post.slug %>" target="_blank" class="btn btn-ghost">View ↗</a>
        <% } %>
        <button type="submit" class="btn btn-primary">💾 Save</button>
      </div>
    </div>

    <div class="editor-layout">
      <div class="editor-main">
        <input type="text" name="title" class="editor-title" placeholder="Post title" required
               value="<%= post ? post.title : '' %>">

        <div class="toolbar">
          <button type="button" data-md="bold" title="Bold (Ctrl+B)"><strong>B</strong></button>
          <button type="button" data-md="italic" title="Italic (Ctrl+I)"><em>I</em></button>
          <button type="button" data-md="h2" title="Heading 2">H2</button>
          <button type="button" data-md="h3" title="Heading 3">H3</button>
          <button type="button" data-md="link" title="Link">🔗</button>
          <button type="button" data-md="image" title="Image">🖼</button>
          <button type="button" data-md="code" title="Code">{ }</button>
          <button type="button" data-md="quote" title="Quote">❝</button>
          <button type="button" data-md="ul" title="List">≡</button>
          <span class="text-small text-muted" id="save-status" style="margin-left:auto;align-self:center"></span>
        </div>

        <textarea name="markdown" id="markdown-editor" class="editor-textarea" placeholder="Start writing in Markdown..."><%= post ? post.markdown : '' %></textarea>
      </div>

      <aside class="editor-sidebar">
        <div class="card">
          <div class="form-group">
            <label>Status</label>
            <select name="status">
              <option value="draft" <%= (!post || post.status === 'draft') ? 'selected' : '' %>>Draft</option>
              <option value="published" <%= (post && post.status === 'published') ? 'selected' : '' %>>Published</option>
            </select>
          </div>

          <div class="form-group">
            <label>Visibility</label>
            <select name="visibility">
              <option value="public" <%= (!post || post.visibility === 'public') ? 'selected' : '' %>>Public</option>
              <option value="private" <%= (post && post.visibility === 'private') ? 'selected' : '' %>>Private</option>
            </select>
          </div>

          <div class="form-group">
            <label class="checkbox-row">
              <input type="checkbox" name="featured" value="1" <%= (post && post.featured) ? 'checked' : '' %>>
              <span>⭐ Featured post</span>
            </label>
          </div>

          <div class="form-group">
            <label>Feature Image URL</label>
            <input type="url" name="feature_image" placeholder="https://..."
                   value="<%= post && post.feature_image ? post.feature_image : '' %>">
            <p class="help-text">Paste URL gambar (Unsplash, Imgur, Cloudinary, etc.)</p>
          </div>

          <div class="form-group">
            <label>Tags</label>
            <input type="text" name="tags" placeholder="tech, javascript" value="<%= tagsString %>">
            <p class="help-text">Pisahkan dengan koma.</p>
          </div>

          <div class="form-group">
            <label>Excerpt</label>
            <textarea name="excerpt" rows="3" placeholder="Custom excerpt"><%= post && post.excerpt ? post.excerpt : '' %></textarea>
            <p class="help-text">Auto-generate kalau kosong.</p>
          </div>

          <details>
            <summary style="cursor:pointer;font-weight:600;margin-bottom:10px">SEO</summary>
            <div class="form-group">
              <label>Meta title</label>
              <input type="text" name="meta_title" value="<%= post && post.meta_title ? post.meta_title : '' %>">
            </div>
            <div class="form-group">
              <label>Meta description</label>
              <textarea name="meta_description" rows="2"><%= post && post.meta_description ? post.meta_description : '' %></textarea>
            </div>
          </details>

          <% if (post) { %>
            <hr style="border:none;border-top:1px solid var(--border);margin:16px 0">
            <p class="text-small text-muted">
              Views: <%= post.views || 0 %><br>
              Slug: <code><%= post.slug %></code>
            </p>
          <% } %>
        </div>
      </aside>
    </div>
  </form>
</div>

<script src="/js/editor.js"></script>
</body>
</html>
